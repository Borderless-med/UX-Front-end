{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "sg-smile-saver.vercel.app"
        }
      ],
      "destination": "https://orachope.org/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-expired-bookings",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/send-urgent-nudges",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/send-appointment-reminders",
      "schedule": "0 * * * *"
    }
  ]
}
# ============================================
# ENVIRONMENT VARIABLES - LOCAL DEVELOPMENT
# Copy this to .env and fill in your actual values
# NEVER commit .env to git!
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email Services
SMTP2GO_API_KEY=your-smtp2go-api-key
BREVO_API_KEY=your-brevo-api-key
SMTP_USER=contact@orachope.org

# Security Secrets
CANCEL_SECRET=your-existing-cancel-secret
CRON_SECRET=generate-random-32-char-string
HMAC_SECRET=generate-another-random-32-char-string

# Bot Protection (Cloudflare Turnstile) - Get free keys at https://dash.cloudflare.com/
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# WhatsApp (set when Meta approves)
WHATSAPP_ENABLED=false
WHATSAPP_API_TOKEN=your-whatsapp-token-when-ready
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-when-ready

# ============================================
# HOW TO GENERATE SECRETS (PowerShell):
# [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
# ============================================
